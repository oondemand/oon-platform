# Identidade
SERVICE_NAME=central-exemplo
SERVICE_VERSION=0.1.0
PORT=4000
NODE_ENV=development

# Banco (ou use MONGO_URI direto)
MONGO_URI=mongodb://localhost:27017/central-exemplo
# DB_SERVER=mongodb://localhost:27017
# DB_NAME=central-exemplo
# DB_USER=
# DB_PASSWORD=

# Autenticação (Central de Ativações)
MEUS_APPS_BACKEND_URL=https://central-ativacao.example.com
# Código cadastrado no campo `codigo` do App na Central de Ativações.
# Fica somente no backend e é enviado automaticamente no login/validação.
APP_CODE=central-exemplo

# DEV ONLY: aceita qualquer token e resolve um admin local (sem Central de Ativações).
# Ligue para rodar a stack no navegador localmente. NUNCA em produção.
DEV_FAKE_AUTH=true

# Omie (opcional — se ausente, o sync vira no-op)
# OMIE_APP_KEY=
# OMIE_APP_SECRET=

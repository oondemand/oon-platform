# Identidade
SERVICE_NAME=central-exemplo
SERVICE_VERSION=0.1.0
PORT=4000
NODE_ENV=development

# Banco (ou use MONGO_URI direto)
MONGO_URI=mongodb://localhost:27017/central-exemplo
# DB_SERVER=mongodb://localhost:27017
# DB_NAME=central-exemplo
# DB_USER=
# DB_PASSWORD=

# Autenticação (provedor padrão: Meus Apps)
MEUS_APPS_BACKEND_URL=https://meus-apps.example.com
APP_KEY=

# DEV ONLY: aceita qualquer token e resolve um admin local (sem Meus Apps).
# Ligue para rodar a stack no navegador localmente. NUNCA em produção.
DEV_FAKE_AUTH=true

# Omie (opcional — se ausente, o sync vira no-op)
# OMIE_APP_KEY=
# OMIE_APP_SECRET=

# Identidade
SERVICE_NAME=central-exemplo
SERVICE_VERSION=0.1.0
PORT=4000
NODE_ENV=development

# Banco (ou use MONGO_URI direto)
MONGO_URI=mongodb://localhost:27017/central-exemplo
# DB_SERVER=mongodb://localhost:27017
# DB_NAME=central-exemplo
# DB_USER=
# DB_PASSWORD=

# Autenticação e autorização pela Central de Ativações
CENTRAL_ATIVACAO_URL=http://localhost:4100
APP_CODE=central-exemplo
# Compatibilidade temporária: MEUS_APPS_BACKEND_URL e APP_KEY também são aceitas.

# DEV ONLY: sobrescreve a validação remota e resolve um admin local.
# NUNCA habilitar em produção.
DEV_FAKE_AUTH=true

# Omie (opcional — se ausente, o sync vira no-op)
# OMIE_APP_KEY=
# OMIE_APP_SECRET=

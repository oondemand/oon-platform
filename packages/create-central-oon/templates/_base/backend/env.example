# Identidade
SERVICE_NAME=__SLUG__
SERVICE_VERSION=0.1.0
PORT=4000
NODE_ENV=development

# Banco
MONGO_URI=mongodb://localhost:27017/__SLUG__

# Autenticação (provedor padrão: Meus Apps)
MEUS_APPS_BACKEND_URL=https://meus-apps.example.com
APP_KEY=

# Token de desenvolvimento local (sem Meus Apps).
# Deve ser igual ao VITE_DEV_TOKEN configurado no frontend.
DEV_TOKEN=dev-local

# Identidade
SERVICE_NAME=__SLUG__
SERVICE_VERSION=0.1.0
PORT=4000
NODE_ENV=development

# Banco
MONGO_URI=mongodb://localhost:27017/__SLUG__

# Autenticação e autorização pela Central de Ativações
CENTRAL_ATIVACAO_URL=http://localhost:4100
APP_CODE=__SLUG__
# Compatibilidade temporária: MEUS_APPS_BACKEND_URL e APP_KEY também são aceitas.

# Token de desenvolvimento local (quando a Central sobrescrever verifyToken).
# Deve ser igual ao VITE_DEV_TOKEN configurado no frontend.
DEV_TOKEN=dev-local

# URL do backend da Central (oonCore-back)
VITE_API_URL=http://localhost:4000

# Login externo (Meus Apps) — redirecionamento quando sem sessão
VITE_MEUS_APPS_URL=https://meus-apps.example.com

# Desenvolvimento local: deve ser igual ao DEV_TOKEN do backend.
# O frontend envia este token para /auth/validar-token antes de qualquer redirect.
VITE_DEV_TOKEN=dev-local
